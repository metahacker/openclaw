{
  "name": "@openclaw/twilio-sms",
  "version": "2026.3.3",
  "description": "Twilio SMS/MMS channel plugin for OpenClaw",
  "type": "module",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "twilio-sms",
      "label": "Twilio SMS",
      "selectionLabel": "Twilio SMS/MMS",
      "docsPath": "/channels/twilio-sms",
      "docsLabel": "twilio-sms",
      "blurb": "Send and receive SMS/MMS messages via Twilio Programmable Messaging.",
      "order": 85
    },
    "install": {
      "npmSpec": "@openclaw/twilio-sms",
      "localPath": "extensions/twilio-sms",
      "defaultChoice": "npm"
    }
  }
}
